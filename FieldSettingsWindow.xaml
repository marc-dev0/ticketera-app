<Window x:Class="TicketeraApp.FieldSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="icon.png"
        SizeToContent="Height"
        MinHeight="200"
        Width="360"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleBlock" FontWeight="Bold" FontSize="14"
                   Margin="0,0,0,15" Foreground="DarkSlateGray"/>

        <!-- Eje X / Eje Y -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Label Content="Posición X (horizontal):" FontSize="11"/>
                <TextBox x:Name="XTextBox" Padding="5"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <Label Content="Posición Y (vertical):" FontSize="11"/>
                <TextBox x:Name="YTextBox" Padding="5"/>
            </StackPanel>
        </Grid>

        <!-- Altura -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Alto (dots) – 0 = automático:" FontSize="11"
                   ToolTip="Para el Código de Barras este es el alto físico de las barras. Para el texto controla el tamaño vertical."/>
            <TextBox x:Name="HeightTextBox" Padding="5"/>
        </StackPanel>

        <!-- Escala de Fuente (solo para campos de texto) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15" x:Name="FontScalePanel">
            <Label Content="Tamaño de Fuente:" FontSize="11"/>
            <ComboBox x:Name="FontScaleComboBox" Padding="5">
                <ComboBoxItem Content="1 – Pequeño (recomendado)" Tag="1"/>
                <ComboBoxItem Content="2 – Mediano" Tag="2"/>
            </ComboBox>
        </StackPanel>

        <!-- Botones Aceptar / Cancelar -->
        <Grid Grid.Row="4" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Aceptar" Height="35" Margin="0,0,8,0"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Grid.Column="1" Content="Cancelar" Height="35"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>
