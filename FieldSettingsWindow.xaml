<Window x:Class="TicketeraApp.FieldSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="icon.png"
        SizeToContent="Height"
        MinHeight="200"
        Width="360"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleBlock" FontWeight="Bold" FontSize="14"
                   Margin="0,0,0,15" Foreground="DarkSlateGray"/>

        <!-- Eje X / Eje Y -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Label Content="Posición X (horizontal):" FontSize="11"/>
                <TextBox x:Name="XTextBox" Padding="5"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <Label Content="Posición Y (vertical):" FontSize="11"/>
                <TextBox x:Name="YTextBox" Padding="5"/>
            </StackPanel>
        </Grid>

        <!-- Altura -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Alto (dots) – 0 = automático:" FontSize="11"
                   ToolTip="Para el Código de Barras este es el alto físico de las barras. Para el texto controla el tamaño vertical."/>
            <TextBox x:Name="HeightTextBox" Padding="5"/>
        </StackPanel>

        <!-- Configuración de Fuente (solo para campos de texto) -->
        <Grid Grid.Row="3" Margin="0,0,0,15" x:Name="FontScalePanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Label Content="Tipo de Letra:" FontSize="11"/>
                <ComboBox x:Name="FontTypeComboBox" Padding="5">
                    <ComboBoxItem Content="1 (8x12 Puntos - Pequeña)" Tag="1"/>
                    <ComboBoxItem Content="2 (12x20 Puntos - Mediana)" Tag="2"/>
                    <ComboBoxItem Content="3 (16x24 Puntos - Mediana)" Tag="3"/>
                    <ComboBoxItem Content="4 (24x32 Puntos - Grande)" Tag="4"/>
                    <ComboBoxItem Content="5 (32x48 Puntos - Muy Grande)" Tag="5"/>
                    <ComboBoxItem Content="8 (OCR-B)" Tag="8"/>
                    <ComboBoxItem Content="ROMAN.TTF (Letra Curva)" Tag="ROMAN.TTF"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <Label Content="Tamaño (1-10):" FontSize="11"/>
                <ComboBox x:Name="FontSizeComboBox" Padding="5">
                    <ComboBoxItem Content="1" Tag="1"/>
                    <ComboBoxItem Content="2" Tag="2"/>
                    <ComboBoxItem Content="3" Tag="3"/>
                    <ComboBoxItem Content="4" Tag="4"/>
                    <ComboBoxItem Content="5" Tag="5"/>
                    <ComboBoxItem Content="6" Tag="6"/>
                    <ComboBoxItem Content="7" Tag="7"/>
                    <ComboBoxItem Content="8" Tag="8"/>
                    <ComboBoxItem Content="9" Tag="9"/>
                    <ComboBoxItem Content="10" Tag="10"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Botones Aceptar / Cancelar -->
        <Grid Grid.Row="4" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Aceptar" Height="35" Margin="0,0,8,0"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Grid.Column="1" Content="Cancelar" Height="35"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>
