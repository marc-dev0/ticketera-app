<Window x:Class="TicketeraApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Impresión de Etiquetas – CBX T30 (3 columnas)" Height="680" Width="460"
        Icon="icon.png"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- IMPRESORA -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Label Content="Seleccionar Impresora (ej. CBX T30):" FontWeight="Bold"/>
            <ComboBox x:Name="PrinterComboBox" Padding="5"/>
        </StackPanel>

        <!-- CONFIG GLOBAL -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Label Content="Offset Col. 1 (dots):" FontWeight="Bold"
                       ToolTip="Mueve solo la primera columna a la derecha. Útil cuando el ribbon sale pegado al borde izquierdo."/>
                <TextBox x:Name="FirstColumnOffsetTextBox" Padding="5" Text="20"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <Label Content="Margen global (dots):" FontWeight="Bold"
                       ToolTip="Mueve las 3 columnas uniformemente."/>
                <TextBox x:Name="GlobalOffsetXTextBox" Padding="5" Text="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Separación Columnas:" FontWeight="Bold"/>
                <TextBox x:Name="SpacingTextBox" Padding="5" Text="280"/>
            </StackPanel>
        </Grid>

        <!-- NOMBRE DEL PRODUCTO -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <CheckBox x:Name="EnableProductNameCheckBox" Content="Incluir Nombre del Producto"
                              IsChecked="True" VerticalAlignment="Center"
                              Checked="EnableProductNameCheckBox_Changed"
                              Unchecked="EnableProductNameCheckBox_Changed"/>
                </StackPanel>
                <TextBox x:Name="ProductNameTextBox" Padding="5" Text="" MaxLength="20"/>
            </StackPanel>
            <Button Grid.Column="1" Content="⚙" Width="32" Height="32" Margin="8,18,0,0"
                    VerticalAlignment="Bottom" ToolTip="Configurar posición y estilo del Nombre"
                    Click="ConfigNameButton_Click"/>
        </Grid>

        <!-- CÓDIGO EAN-13 -->
        <Grid Grid.Row="3" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Código EAN-13 (ingresar solo 12 dígitos, verificador es auto):" FontWeight="Bold"/>
                <TextBox x:Name="SkuTextBox" Padding="5" Text="" MaxLength="12"
                         TextChanged="SkuTextBox_TextChanged"/>
                <TextBlock x:Name="CheckDigitHintBlock" Margin="3,4,0,0" FontSize="11"
                           Foreground="#007ACC" Visibility="Collapsed"/>
                <TextBlock Text="💡 Para uso interno usa prefijo 20-29 (ej: 200000000000)"
                           FontSize="10" Foreground="Gray" Margin="3,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <Button Grid.Column="1" Content="⚙" Width="32" Height="32" Margin="8,18,0,0"
                    VerticalAlignment="Bottom" ToolTip="Configurar posición del Código de Barras"
                    Click="ConfigBarcodeButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="4" x:Name="EanValidationWarning" Margin="5,0,0,10"
                   Text="⚠ El código EAN-13 debe contener solo números."
                   Foreground="DarkOrange" Visibility="Collapsed"/>

        <!-- PRECIO -->
        <Grid Grid.Row="5" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <CheckBox x:Name="EnablePriceCheckBox" Content="Incluir Precio"
                              IsChecked="True" VerticalAlignment="Center"
                              Checked="EnablePriceCheckBox_Changed"
                              Unchecked="EnablePriceCheckBox_Changed"/>
                </StackPanel>
                <TextBox x:Name="PriceTextBox" Padding="5" Text="S/ 250.00" MaxLength="9"/>
            </StackPanel>
            <Button Grid.Column="1" Content="⚙" Width="32" Height="32" Margin="8,18,0,0"
                    VerticalAlignment="Bottom" ToolTip="Configurar posición y estilo del Precio"
                    Click="ConfigPriceButton_Click"/>
        </Grid>

        <!-- CANTIDAD DE FILAS -->
        <Grid Grid.Row="6" Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Cantidad de Filas a imprimir:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" x:Name="PrintQuantityTextBox" Padding="5" Text="1" Width="60" HorizontalAlignment="Left" MaxLength="3"/>
        </Grid>

        <!-- IMPRIMIR -->
        <Button Grid.Row="7" x:Name="PrintButton" Margin="0,20,0,5"
                Content="🖨 Imprimir Fila de 3 Etiquetas"
                IsDefault="True"
                Height="45" Background="#007ACC" Foreground="White" FontWeight="Bold" FontSize="14"
                Click="PrintButton_Click"/>

        <!-- HISTORIAL -->
        <Button Grid.Row="8" Content="📋 Ver Historial de Códigos"
                Height="34" Margin="0,0,0,0"
                Background="#1A5276" Foreground="White" FontWeight="SemiBold"
                Click="HistoryButton_Click"/>

        <TextBlock Grid.Row="9" x:Name="StatusTextBlock" Margin="0,10,0,0"
                   TextWrapping="Wrap" Foreground="Green" VerticalAlignment="Bottom"/>

        <!-- BOTON NUEVO CODIGO (solo visible en modo reimpresion) -->
        <Button Grid.Row="10" x:Name="NewCodeButton"
                Content="+ Crear Nuevo Código"
                Height="30" Margin="0,6,0,0"
                Visibility="Collapsed"
                Background="#27AE60" Foreground="White" FontWeight="SemiBold" FontSize="12"
                Click="NewCodeButton_Click"/>

        <!-- FOOTER / COPYRIGHT -->
        <TextBlock Grid.Row="11" Text="Desarrollado por Miguel Rojas © 2026"
                   Margin="0,10,0,0" FontSize="11" Foreground="Gray"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
