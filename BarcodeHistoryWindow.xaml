<Window x:Class="TicketeraApp.BarcodeHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Historial de Códigos EAN-13"
        Height="520" Width="720"
        Icon="icon.png"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="📋 Historial de Códigos EAN-13 Generados"
                       FontSize="16" FontWeight="Bold" Foreground="#1A5276"/>
            <TextBlock x:Name="SubtitleBlock"
                       FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🔍 Buscar:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#1A5276" FontWeight="SemiBold"/>
            <TextBox Grid.Column="1" x:Name="SearchTextBox" Padding="4" TextChanged="SearchTextBox_TextChanged" 
                     ToolTip="Buscar por código EAN-13 o nombre de producto"/>
        </Grid>

        <!-- Hint para reimprimir -->
        <TextBlock Grid.Row="2" Margin="0,0,0,8" FontSize="11" Foreground="#1A5276"
                   Text="💡 Doble clic en una fila (o selecciónala y usa el botón Reimprimir) para cargarla en el formulario principal."/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F2F9FF"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  BorderBrush="#CCCCCC" BorderThickness="1"
                  MouseDoubleClick="HistoryGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código EAN-13"   Binding="{Binding Code}"        Width="155"/>
                <DataGridTextColumn Header="Nombre Producto" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Precio"          Binding="{Binding Price}"       Width="90"/>
                <DataGridTextColumn Header="Fecha"
                                    Binding="{Binding RegisteredAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                    Width="130"/>
                <!-- Delete button column -->
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑" Width="28" Height="22"
                                    Padding="0" FontSize="12"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#C0392B" Cursor="Hand"
                                    ToolTip="Eliminar este registro"
                                    Tag="{Binding Code}"
                                    Click="DeleteRowButton_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom bar -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="StatusBlock"
                       VerticalAlignment="Center" Foreground="#555" FontSize="11"/>

            <Button Grid.Column="1" Content="✔ Reimprimir seleccionado"
                    Width="180" Height="34" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"
                    ToolTip="Selecciona una fila primero, luego haz clic aquí"
                    Click="SelectForReprintButton_Click"/>

            <Button Grid.Column="2" Content="🗑 Limpiar Todo"
                    Width="130" Height="34" Margin="0,0,10,0"
                    Background="#E74C3C" Foreground="White" FontWeight="Bold"
                    Click="ClearButton_Click"/>

            <Button Grid.Column="3" Content="📥 Exportar Excel"
                    Width="140" Height="34" Margin="0,0,10,0"
                    Background="#1A5276" Foreground="White" FontWeight="Bold"
                    Click="ExportButton_Click"/>

            <Button Grid.Column="4" Content="✕ Cerrar"
                    Width="80" Height="34"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
